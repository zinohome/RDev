# RDev 部署环境变量模板
# 复制本文件为 .env 并填写所有必填项
#   cp deploy/.env.example deploy/.env
# ⚠️ .env 已加入 .gitignore，切勿提交到版本控制

# ────────────────────────────────────────────────────
# 数据库（必填）
# ────────────────────────────────────────────────────
POSTGRES_DB=rdev
POSTGRES_USER=rdev
POSTGRES_PASSWORD=change_me_postgres_password

# ────────────────────────────────────────────────────
# 后端安全（必填）
# ────────────────────────────────────────────────────
# JWT 签名密钥（最少 32 字节随机字符串）
# 生成示例：openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# RDev 扩展加密密钥（32 字节，deploy/init.sh 可自动生成）
# 生成示例：openssl rand -hex 32
RDEV_ENCRYPTION_KEY=change_me_rdev_encryption_key_32bytes

# ────────────────────────────────────────────────────
# 前端 / 网络
# ────────────────────────────────────────────────────
# 对外访问地址（不含尾部斜杠）
MULTICA_APP_URL=http://localhost
FRONTEND_ORIGIN=http://localhost

# Web 端口（nginx 对外暴露）
WEB_PORT=80
# WEB_BIND=0.0.0.0   # 修改为 127.0.0.1 可仅本机访问

# 应用版本（可选）
APP_VERSION=latest

# ────────────────────────────────────────────────────
# 模型网关
# ────────────────────────────────────────────────────
# Anthropic API Key（直连 claude.ai 时使用）
ANTHROPIC_API_KEY=

# OpenAI API Key（直连 openai 时使用）
OPENAI_API_KEY=

# Ollama 地址（使用 --profile ollama 时自动填充）
OLLAMA_URL=http://ollama:11434

# vLLM 地址（使用 --profile vllm 时填写）
VLLM_URL=http://vllm:8000

# 模型后端 URL（rdev-server 调用的模型入口）
MODEL_BACKEND_URL=http://rdev-gateway:8090

# 网关对外端口
GATEWAY_PORT=8090

# ────────────────────────────────────────────────────
# Gitea（仅 --profile gitea 时需要）
# ────────────────────────────────────────────────────
# Gitea 数据库名（在 postgres 中自动创建）
GITEA_DB=gitea

# Gitea 安全密钥（必填，使用 gitea profile 时）
# 生成示例：openssl rand -hex 32
GITEA_SECRET_KEY=change_me_gitea_secret_key

# Gitea 内部令牌（可留空，Gitea 自动生成）
GITEA_INTERNAL_TOKEN=

# Gitea 对外 URL（用于克隆链接显示）
GITEA_ROOT_URL=http://localhost:3000

# Gitea 端口
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222

# rdev-server 访问 Gitea 的地址和 admin token
GITEA_URL=http://gitea:3000
GITEA_ADMIN_TOKEN=

# ────────────────────────────────────────────────────
# Ollama（仅 --profile ollama 时需要）
# ────────────────────────────────────────────────────
OLLAMA_PORT=11434

# ────────────────────────────────────────────────────
# vLLM（仅 --profile vllm 时需要，需要 NVIDIA GPU）
# ────────────────────────────────────────────────────
VLLM_PORT=8000
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Hugging Face token（下载受限模型时需要）
HF_TOKEN=

# ────────────────────────────────────────────────────
# 邮件（可选）
# ────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=

# ────────────────────────────────────────────────────
# 高级配置（可选）
# ────────────────────────────────────────────────────
APP_ENV=production
ALLOW_SIGNUP=true
# 限制注册邮箱（逗号分隔）
ALLOWED_EMAILS=
# 限制注册域名（逗号分隔）
ALLOWED_EMAIL_DOMAINS=
# 公开 API 地址（Webhook 回调需要）
MULTICA_PUBLIC_URL=
# 信任的代理 CIDR（同机 nginx 填 127.0.0.1/32）
MULTICA_TRUSTED_PROXIES=127.0.0.1/32
# Prometheus 监控地址（可选）
METRICS_ADDR=
