# RDev 部署环境变量模板
# 使用前请复制为 .env 并按需修改所有标注 CHANGE ME 的值
#
# 生成随机密钥：
#   openssl rand -base64 32   # 用于 JWT_SECRET、RDEV_ENCRYPTION_KEY
#   openssl rand -hex 64      # 用于 GITEA_SECRET_KEY、GITEA_INTERNAL_TOKEN

# ─── 数据库 ───────────────────────────────────────────────────────
POSTGRES_DB=rdev
POSTGRES_USER=rdev
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── 核心安全密钥 ────────────────────────────────────────────────
# 32 字节随机值（由 init.sh 自动生成，若未手动设置）
RDEV_ENCRYPTION_KEY=CHANGE_ME_run_init_sh_to_auto_generate

# JWT 签名密钥（至少 32 字节随机字符串）
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# ─── 服务 URL ────────────────────────────────────────────────────
# 前端对外访问地址（用于 CORS、OAuth 回调等）
FRONTEND_ORIGIN=http://localhost
MULTICA_APP_URL=http://localhost

# 后端公网 URL（Webhook 等需要，留空则使用 FRONTEND_ORIGIN）
MULTICA_PUBLIC_URL=

# 允许 127.0.0.1 作为受信代理（Nginx 同机反代）
MULTICA_TRUSTED_PROXIES=127.0.0.1/32

# 跨域白名单（逗号分隔，留空则只允许 FRONTEND_ORIGIN）
CORS_ALLOWED_ORIGINS=

# ─── 注册策略 ────────────────────────────────────────────────────
# 是否允许公开注册
ALLOW_SIGNUP=true
# 白名单邮箱（逗号分隔），留空不限制
ALLOWED_EMAILS=
# 白名单域名（逗号分隔），留空不限制
ALLOWED_EMAIL_DOMAINS=

# ─── 模型网关 ────────────────────────────────────────────────────
# Anthropic API Key（网关转发到 Anthropic 时使用）
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# 自定义模型后端（vLLM / Ollama 等），留空则使用内置网关
MODEL_BACKEND_URL=

# ─── Gitea VCS 集成 ──────────────────────────────────────────────
# Gitea 服务内部地址（docker 内网）
GITEA_URL=http://gitea:3000
# Gitea 管理员 Token（首次 Gitea 登录后在 Settings > Applications 生成）
GITEA_ADMIN_TOKEN=CHANGE_ME_after_gitea_setup

# Gitea 数据库名（与 postgres 共用同一实例，自动创建）
GITEA_DB=gitea
# Gitea 对外域名（用于 Gitea 自身 clone URL）
GITEA_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3001

# Gitea 加密密钥（openssl rand -hex 64）
GITEA_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_64
GITEA_INTERNAL_TOKEN=CHANGE_ME_run_openssl_rand_hex_64

# ─── 邮件（可选，用于验证码发送）──────────────────────────────
# Resend.com（推荐）
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# SMTP（备选）
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_INSECURE=false

# ─── 对象存储（可选，默认使用本地磁盘）─────────────────────────
S3_BUCKET=
S3_REGION=us-east-1

# ─── 服务端口（宿主机绑定端口，均绑定 127.0.0.1）──────────────
WEB_PORT=80
GITEA_PORT=3001

# ─── 版本标签 ────────────────────────────────────────────────────
RDEV_VERSION=production

# ─── Next.js ─────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=

# ─── 运行模式 ────────────────────────────────────────────────────
APP_ENV=production
